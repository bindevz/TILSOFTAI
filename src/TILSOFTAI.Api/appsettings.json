{
  "ConnectionStrings": {
    "TilsoftAi": ""
  },
  "Ai": {
    "Provider": "OpenAICompatible",
    "OpenAICompatible": {
      "BaseUrl": "",
      "ApiKey": "",
      "ChatModel": "",
      "EmbeddingModel": "",
      "RequestTimeoutSeconds": 120,
      "EmbeddingDimensions": 1536
    }
  },
  "Agent": {
    "MaxToolCalls": 5,
    "MaxRowsPerTool": 5000,
    "MaxExecutionSeconds": 60,
    "RequireArtifactPersistence": true
  },
  "Artifacts": {
    "Provider": "FileSystem",
    "RootPath": ""
  },
  "Security": {
    "RequireTenantHeader": true,
    "RequireUserHeader": true
  },
  "Observability": {
    "ServiceName": "TILSOFTAI",
    "EnableOpenTelemetry": true
  }
}

